import requests
from bs4 import BeautifulSoup
import pandas as pd
import time

url_template = "https://github.com/search?q=mental+health+ai&type=repositories&p={page}"
headers = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
}

all_repos = []

for page in range(1, 6): # Pages 1 à 5
    print(f"Extraction de la page {page}...")
    url = url_template.format(page=page)
    
    response = requests.get(url, headers=headers)
    if response.status_code != 200:
        print(f"Erreur {response.status_code}")
        continue

    soup = BeautifulSoup(response.text, 'html.parser')
    
    repo_items = soup.select('div[data-testid="results-list"] > div')
    
    for item in repo_items:
        try:
            title_tag = item.select_one('a.v-align-middle')
            all_repos.append({
                "title": title_tag.text.strip(),
                "url": "https://github.com" + title_tag['href'],
                "description": item.select_one('p.mb-1').text.strip() if item.select_one('p.mb-1') else "N/A",
                "stars": item.select_one('a.Link--muted').text.strip() if item.select_one('a.Link--muted') else "0"
            })
        except Exception:
            continue
    
    time.sleep(2) 

df = pd.DataFrame(all_repos)
df.to_csv("github_static_results.csv", index=False)
print("Fichier statique enregistré.")
