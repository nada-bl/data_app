from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from webdriver_manager.chrome import ChromeDriverManager
import json
import pandas as pd
import time

def scrape_producthunt():
    chrome_options = Options()
    chrome_options.add_argument("--headless") 
    chrome_options.add_argument("--window-size=1920,1080")
    chrome_options.add_argument("user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36")

    driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=chrome_options)
    url = "https://www.producthunt.com/search?q=mental+health+ai" 

    try:
        driver.get(url) [cite: 173]
        wait = WebDriverWait(driver, 20)
        wait.until(EC.presence_of_element_located((By.CSS_SELECTOR, 'div[data-test="post-item"]'))) [cite: 181]

        items = driver.find_elements(By.CSS_SELECTOR, 'div[data-test="post-item"]')
        results = []

        for item in items:
            try:
                results.append({
                    "name": item.find_element(By.TAG_NAME, "strong").text,
                    "tagline": item.find_element(By.CSS_SELECTOR, 'div[class*="styles_tagline"]').text,
                    "votes": item.find_element(By.CSS_SELECTOR, 'button[data-test="vote-button"]').text
                })
            except Exception: 
                continue

        with open("producthunt_data.json", "w", encoding='utf-8') as f:
            json.dump(results, f, indent=4, ensure_ascii=False)

        df = pd.read_json("producthunt_data.json")
        df.to_csv("producthunt_final.csv", index=False)
        print("Scraping dynamique terminé et fichiers générés.")

    finally:
        driver.quit() [cite: 173]

if __name__ == "__main__":
    scrape_producthunt()
